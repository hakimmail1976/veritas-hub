# ─── VERITAS SCAN™ — Variables d'environnement ───────────────────────────
# Copier ce fichier en .env et remplir toutes les valeurs

# ── Serveur ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
ALLOWED_ORIGINS=chrome-extension://VOTRE_EXTENSION_ID

# ── Base de données ───────────────────────────────────────────────────────
# Créez un cluster gratuit sur https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/veritas-scan

# ── Redis ─────────────────────────────────────────────────────────────────
# Créez un compte gratuit sur https://upstash.com
REDIS_URL=redis://default:PASSWORD@HOST:PORT

# ── JWT ───────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 64
JWT_SECRET=VOTRE_SECRET_JWT_TRES_LONG_ET_ALEATOIRE

# ── Stripe ───────────────────────────────────────────────────────────────
# Récupérez ces clés sur https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXX
# Créez un Price dans Stripe Dashboard (abonnement 4.90€/mois)
STRIPE_PRICE_ID=price_XXXXXXXXXXXXXXXX

# ── Email (SendGrid) ─────────────────────────────────────────────────────
# Créez un compte sur https://sendgrid.com (100 emails/j gratuits)
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXX
EMAIL_FROM=noreply@votredomaine.com
EMAIL_FROM_NAME=VERITAS SCAN

# ── APIs d'analyse forensique ─────────────────────────────────────────────
# https://sightengine.com — Créez un compte, récupérez api_user et api_secret
SIGHTENGINE_API_USER=XXXXXXX
SIGHTENGINE_API_SECRET=XXXXXXXXXXXXXXXX

# https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Google Safe Browsing — https://developers.google.com/safe-browsing/v4/get-started
GOOGLE_SAFE_BROWSING_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── URL publique du serveur ───────────────────────────────────────────────
SERVER_URL=https://votredomaine.com
